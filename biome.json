{
	"$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!**/.turnkey/",
			"!**/.devenv/",
			"!**/buck-out/",
			"!**/target/",
			"!**/node_modules/"
		]
	},
	"formatter": {
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true
	}
}
