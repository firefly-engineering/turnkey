# Turnkey: Generate go-deps.toml to Nix store before flake evaluation
# This ensures dependencies are Nix-managed without committing go-deps.toml
if [ -f go.mod ]; then
  mkdir -p .turnkey
  _needs_gen=0

  if [ ! -L .turnkey/go-deps.toml ]; then
    _needs_gen=1
  elif [ go.mod -nt .turnkey/go-deps.toml ]; then
    _needs_gen=1
  elif [ -f go.sum ] && [ go.sum -nt .turnkey/go-deps.toml ]; then
    _needs_gen=1
  fi

  if [ "$_needs_gen" = "1" ]; then
    echo "turnkey: Generating go-deps.toml to Nix store..."
    _tmp=$(mktemp)
    if nix run .#godeps-gen -- --go-mod go.mod --go-sum go.sum --prefetch > "$_tmp" 2>&1; then
      _store_path=$(nix store add-file --name go-deps.toml "$_tmp")
      rm "$_tmp"
      ln -sf "$_store_path" .turnkey/go-deps.toml
      echo "turnkey: .turnkey/go-deps.toml -> $_store_path"
    else
      cat "$_tmp"  # Show error
      rm -f "$_tmp"
      echo "turnkey: Warning: Failed to generate go-deps.toml"
    fi
  fi
fi

use flake . --no-pure-eval

# Watch for dependency changes - triggers regeneration
watch_file nix/**/*.nix
watch_file go.mod
watch_file go.sum
