# Turnkey dependency auto-regeneration
# Uses hash-based staleness detection for reliable change detection

TURNKEY_DEPS_CACHE=".turnkey-deps-hashes"

# Compute combined SHA256 hash of files (empty string if files don't exist)
_turnkey_hash_files() {
  local files="$@"
  local hash=""
  for f in $files; do
    if [ -f "$f" ]; then
      hash="${hash}$(sha256sum "$f" 2>/dev/null | cut -d' ' -f1)"
    fi
  done
  if [ -n "$hash" ]; then
    echo "$hash" | sha256sum | cut -d' ' -f1
  fi
}

# Get cached hash for a key
_turnkey_get_cached_hash() {
  local key="$1"
  if [ -f "$TURNKEY_DEPS_CACHE" ]; then
    grep "^${key}=" "$TURNKEY_DEPS_CACHE" 2>/dev/null | cut -d'=' -f2
  fi
}

# Set cached hash for a key
_turnkey_set_cached_hash() {
  local key="$1"
  local hash="$2"
  # Remove old entry and add new one
  if [ -f "$TURNKEY_DEPS_CACHE" ]; then
    grep -v "^${key}=" "$TURNKEY_DEPS_CACHE" > "${TURNKEY_DEPS_CACHE}.tmp" 2>/dev/null || true
    mv "${TURNKEY_DEPS_CACHE}.tmp" "$TURNKEY_DEPS_CACHE"
  fi
  echo "${key}=${hash}" >> "$TURNKEY_DEPS_CACHE"
}

# Check if regeneration is needed (hash mismatch or output missing)
_turnkey_needs_regen() {
  local key="$1"
  local output="$2"
  shift 2
  local inputs="$@"

  # Always regenerate if output doesn't exist
  if [ ! -f "$output" ]; then
    return 0
  fi

  # Compute current hash of inputs
  local current_hash=$(_turnkey_hash_files $inputs)
  local cached_hash=$(_turnkey_get_cached_hash "$key")

  # Regenerate if hash changed or no cache entry
  if [ "$current_hash" != "$cached_hash" ]; then
    return 0
  fi

  return 1
}

# Load the flake first so tools are available
use flake . --no-pure-eval

# Go: Auto-regenerate go-deps.toml when go.mod/go.sum change
if [ -f go.mod ]; then
  if _turnkey_needs_regen "go" "go-deps.toml" go.mod go.sum; then
    echo "turnkey: Regenerating go-deps.toml..."
    if godeps-gen --go-mod go.mod --go-sum go.sum --prefetch -o go-deps.toml.tmp; then
      mv go-deps.toml.tmp go-deps.toml
      _turnkey_set_cached_hash "go" "$(_turnkey_hash_files go.mod go.sum)"
      echo "turnkey: Updated go-deps.toml (remember to commit)"
    else
      rm -f go-deps.toml.tmp
      echo "turnkey: Warning: Failed to generate go-deps.toml"
    fi
  fi
fi

# Python: Auto-regenerate python-deps.toml when pyproject.toml changes
# Uses uv for lock file generation and pydeps-gen for Nix hash prefetching
if [ -f pyproject.toml ]; then
  if _turnkey_needs_regen "python" "python-deps.toml" pyproject.toml; then
    echo "turnkey: Regenerating python-deps.toml..."
    if uv lock 2>&1 && \
       uv export --format pylock.toml -o pylock.toml 2>&1 && \
       pydeps-gen --lock pylock.toml -o python-deps.toml 2>&1; then
      _turnkey_set_cached_hash "python" "$(_turnkey_hash_files pyproject.toml)"
      echo "turnkey: Updated python-deps.toml (remember to commit pylock.toml, uv.lock, python-deps.toml)"
    else
      echo "turnkey: Warning: Failed to generate python-deps.toml"
    fi
  fi
fi

# Rust: Auto-regenerate rust-deps.toml when Cargo.toml/Cargo.lock change
if [ -f Cargo.lock ]; then
  if _turnkey_needs_regen "rust" "rust-deps.toml" Cargo.toml Cargo.lock; then
    echo "turnkey: Regenerating rust-deps.toml..."
    if rustdeps-gen --cargo-lock Cargo.lock -o rust-deps.toml 2>&1; then
      _turnkey_set_cached_hash "rust" "$(_turnkey_hash_files Cargo.toml Cargo.lock)"
      echo "turnkey: Updated rust-deps.toml (remember to commit)"
    else
      echo "turnkey: Warning: Failed to generate rust-deps.toml"
    fi
  fi
fi

# Watch for dependency changes - triggers regeneration
watch_file nix/**/*.nix
watch_file nix/**/*.patch
watch_file go.mod
watch_file go.sum
watch_file pyproject.toml
watch_file Cargo.toml
watch_file Cargo.lock

# Sync symlinks on every direnv reload
# enterShell only runs on initial shell entry, not on reloads,
# so we need to update symlinks here to keep them in sync
if [ -n "$TURNKEY_BUCK2_CONFIG" ]; then
  if [ "$(readlink .buckconfig 2>/dev/null)" != "$TURNKEY_BUCK2_CONFIG" ]; then
    ln -sf "$TURNKEY_BUCK2_CONFIG" .buckconfig
    echo "turnkey: Synced .buckconfig symlink"
  fi
fi
if [ -n "$TURNKEY_BUCK2_TOOLCHAINS_CELL" ]; then
  mkdir -p .turnkey
  if [ "$(readlink .turnkey/toolchains 2>/dev/null)" != "$TURNKEY_BUCK2_TOOLCHAINS_CELL" ]; then
    ln -sfn "$TURNKEY_BUCK2_TOOLCHAINS_CELL" .turnkey/toolchains
    echo "turnkey: Synced toolchains cell symlink"
  fi
fi
# Sync Nix-backed cells (TURNKEY_CELL_<NAME>=<path>:<derivation>)
for var in $(env | grep '^TURNKEY_CELL_' | cut -d= -f1); do
  value="${!var}"
  cell_path="${value%%:*}"
  cell_deriv="${value#*:}"
  if [ "$(readlink "$cell_path" 2>/dev/null)" != "$cell_deriv" ]; then
    mkdir -p "$(dirname "$cell_path")"
    ln -sfn "$cell_deriv" "$cell_path"
    echo "turnkey: Synced $cell_path symlink"
  fi
done
