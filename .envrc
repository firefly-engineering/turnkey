# Turnkey: Generate go-deps.toml before flake evaluation
# This ensures dependencies are available without committing go-deps.toml
if [ -f go.mod ]; then
  mkdir -p .turnkey
  _needs_gen=0

  if [ ! -f .turnkey/go-deps.toml ]; then
    _needs_gen=1
  elif [ go.mod -nt .turnkey/go-deps.toml ]; then
    _needs_gen=1
  elif [ -f go.sum ] && [ go.sum -nt .turnkey/go-deps.toml ]; then
    _needs_gen=1
  fi

  if [ "$_needs_gen" = "1" ]; then
    echo "turnkey: Generating .turnkey/go-deps.toml..."
    if nix run .#godeps-gen -- --go-mod go.mod --go-sum go.sum --prefetch > .turnkey/go-deps.toml.tmp 2>&1; then
      mv .turnkey/go-deps.toml.tmp .turnkey/go-deps.toml
      echo "turnkey: Generated .turnkey/go-deps.toml"
    else
      cat .turnkey/go-deps.toml.tmp  # Show error
      rm -f .turnkey/go-deps.toml.tmp
      echo "turnkey: Warning: Failed to generate go-deps.toml"
    fi
  fi
fi

use flake . --no-pure-eval

# Watch for dependency changes - triggers regeneration
watch_file nix/**/*.nix
watch_file go.mod
watch_file go.sum
