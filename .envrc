# Turnkey development environment
#
# This .envrc uses the turnkey direnv library generated by Nix.
# The library provides use_turnkey which handles:
#   - Dependency file regeneration (go-deps.toml, python-deps.toml, rust-deps.toml)
#   - Buck2 symlink management (.buckconfig, cell symlinks)
#   - watch_file declarations for automatic reloads
#
# Flags: --skip-regen, --skip-sync, --skip-watch, --only-go, --skip-python, etc.
# Env vars: TURNKEY_SKIP_ALL, TURNKEY_ENABLE_GO, TURNKEY_SKIP_PYTHON, etc.

# Load the flake first to make tools available
use flake . --no-pure-eval

# Source the turnkey library and activate
source "$TURNKEY_DIRENV_LIB"
use_turnkey
