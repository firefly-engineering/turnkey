# Turnkey: Auto-regenerate go-deps.toml when go.mod/go.sum change
# The file is tracked in git but auto-updated by .envrc
if [ -f go.mod ]; then
  _needs_gen=0

  if [ ! -f go-deps.toml ]; then
    _needs_gen=1
  elif [ go.mod -nt go-deps.toml ]; then
    _needs_gen=1
  elif [ -f go.sum ] && [ go.sum -nt go-deps.toml ]; then
    _needs_gen=1
  fi

  if [ "$_needs_gen" = "1" ]; then
    echo "turnkey: Regenerating go-deps.toml..."
    if nix run .#godeps-gen -- --go-mod go.mod --go-sum go.sum --prefetch > go-deps.toml.tmp 2>&1; then
      mv go-deps.toml.tmp go-deps.toml
      echo "turnkey: Updated go-deps.toml (remember to commit)"
    else
      cat go-deps.toml.tmp  # Show error
      rm -f go-deps.toml.tmp
      echo "turnkey: Warning: Failed to generate go-deps.toml"
    fi
  fi
fi

use flake . --no-pure-eval

# Watch for dependency changes - triggers regeneration
watch_file nix/**/*.nix
watch_file go.mod
watch_file go.sum
