# Rust example with external crate dependencies
#
# NOTE: This example requires reindeer to generate Buck2 targets
# for external Rust crates. The dependency on //third-party/rust:clap
# would be generated by reindeer from a Cargo.toml specification.
#
# Full setup requires:
# 1. third-party/rust/Cargo.toml with dependencies
# 2. Running: reindeer --third-party-dir third-party/rust buckify
# 3. This generates BUCK files for all crate dependencies
#
# See: https://github.com/facebookincubator/reindeer
# See: https://steveklabnik.com/writing/using-cratesio-with-buck/

load("@prelude//:rules.bzl", "rust_binary")

# This target will fail until reindeer generates third-party crates
rust_binary(
    name = "rust-hello-deps",
    srcs = ["main.rs"],
    edition = "2021",
    # Uncomment when third-party crates are available:
    # deps = [
    #     "//third-party/rust:clap",
    # ],
    visibility = ["PUBLIC"],
)
