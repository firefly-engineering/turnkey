# TypeScript example with external npm dependencies
#
# NOTE: External npm packages require worker-based js rules.
# Buck2's bundled prelude has js_library but needs custom worker setup.
#
# Full setup requires:
# 1. Node.js worker tool configured
# 2. npm packages vendored or fetched
# 3. js_library targets for each dependency
#
# This is more complex than Go/Rust/Python due to npm ecosystem.
# See turnkey-ce6 for native TypeScript toolchain work.

load("@prelude//:rules.bzl", "genrule")

# Placeholder - would need proper npm/worker integration
genrule(
    name = "compile",
    srcs = ["hello.ts"],
    out = "hello.js",
    # This won't work without chalk installed - placeholder only
    cmd = "tsc $(location :hello.ts) --outFile $OUT --target ES2020 --module commonjs",
    visibility = ["PUBLIC"],
)
