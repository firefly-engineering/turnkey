# Go dependencies cell builder
#
# Reads a go-deps.toml file and builds a Buck2 cell containing
# all dependencies with rules.star files generated by buckgen.
#
# The TOML file format:
#   [deps."github.com/foo/bar"]
#   version = "v1.0.0"
#   hash = "sha256-..."
#
# This is now a thin wrapper around the deps-cell library.

{
  pkgs,
  lib,
  depsFile,
  buckgen,
}:

let
  depsCell = import ../lib/deps-cell { inherit pkgs lib; };
in
depsCell.mkGoDepsCell {
  inherit depsFile buckgen;
}
